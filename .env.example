# ─── Application ─────────────────────────────────────────────
APP_NAME="Ogami ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost

# ─── Logging ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (PostgreSQL 16) ────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=ogami
DB_USERNAME=ogami
DB_PASSWORD=ogami_dev_pw

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ─── Cache + Queue ───────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=reverb

# ─── Session (HTTP-only cookies — NEVER tokens) ──────────────
SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

# ─── Sanctum SPA cookie auth ─────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:80

# ─── HashIDs (URL ID obfuscation) ────────────────────────────
HASHIDS_SALT=change_me_to_a_long_random_string_in_production
HASHIDS_LENGTH=10

# ─── Meilisearch ─────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=ogami_meili_dev

# ─── Reverb (WebSocket) ──────────────────────────────────────
REVERB_APP_ID=ogami
REVERB_APP_KEY=ogami_reverb
REVERB_APP_SECRET=ogami_reverb_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Mail (Mailpit in dev) ───────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@ogami.test"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Compose port mappings ───────────────────────────────────
NGINX_PORT=80
MAILPIT_UI_PORT=8025
