APP_NAME="Ogami ERP API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=ogami
DB_USERNAME=ogami
DB_PASSWORD=ogami_dev_pw

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=reverb

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_HTTP_ONLY=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_DOMAIN=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:80

HASHIDS_SALT=change_me_to_a_long_random_string_in_production
HASHIDS_LENGTH=10

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=ogami_meili_dev

REVERB_APP_ID=ogami
REVERB_APP_KEY=ogami_reverb
REVERB_APP_SECRET=ogami_reverb_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="no-reply@ogami.test"
MAIL_FROM_NAME="\${APP_NAME}"
