# ─── Ogami ERP — Production environment template ─────────────────────────
# Copy this file to `.env` on the production VPS and fill in real values.
# DO NOT commit `.env` — only this template lives in git.
# ──────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────
APP_NAME=Ogami
APP_ENV=production
APP_DEBUG=false
APP_KEY=                              # Generate with: php artisan key:generate --show
APP_URL=https://erp.ogami.example     # Replace with the real domain
APP_TIMEZONE=Asia/Manila

# ── Front-end origin (must match APP_URL) ────────────────────────────────
FRONTEND_URL=https://erp.ogami.example
SERVER_NAME=erp.ogami.example

# ── Sanctum SPA cookie auth ──────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=erp.ogami.example
SESSION_DOMAIN=erp.ogami.example
SESSION_SECURE_COOKIE=true
SESSION_DRIVER=database
SESSION_LIFETIME=30

# ── Database (postgres) ──────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=ogami
DB_USERNAME=ogami
DB_PASSWORD=                          # Long random — use `openssl rand -base64 32`

# ── Redis (cache, sessions, queues) ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_DRIVER=reverb

# ── Reverb (WebSocket broadcasting) ──────────────────────────────────────
REVERB_APP_ID=ogami
REVERB_APP_KEY=                       # Long random
REVERB_APP_SECRET=                    # Long random
REVERB_HOST=erp.ogami.example
REVERB_PORT=443
REVERB_SCHEME=https

# ── Meilisearch (full-text search) ───────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=                      # Long random; same value used in compose service

# ── Mail (replace with real SMTP provider) ───────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=erp@ogami.example
MAIL_FROM_NAME="${APP_NAME}"

# ── HashIDs (URL ID obfuscation — must differ from dev!) ────────────────
HASHIDS_SALT=                         # Long random, never share, never change after first deploy

# ── Logging ──────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=warning
